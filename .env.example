# ─── Backend ──────────────────────────────────────────────────────────
# Database
DATABASE_URL=postgresql+asyncpg://alfaleus:alfaleus_dev@localhost:5432/alfaleus_db

# Redis (Celery broker + SSE pub/sub)
REDIS_URL=redis://localhost:6379/0

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434

# Security
SECRET_KEY=your_secret_key_here_change_in_production

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── CRM: Notion ──────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations
# Then share your database with the integration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Custom Search (Optional Fallback for LinkedIn Scraping)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ─── ICP Scoring Defaults ─────────────────────────────────────────────
# Weights must sum to 1.0
ICP_WEIGHT_FIT=0.6
ICP_WEIGHT_SIGNALS=0.4

# Minimum score to trigger outreach draft generation (0-100)
SCORE_THRESHOLD=60

# ─── Frontend ─────────────────────────────────────────────────────────
# (frontend/.env)
# VITE_API_URL=http://localhost:8000/api/v1
