{
  "manifest_version": 3,
  "name": "Alfaleus — Lead Intelligence",
  "version": "1.0.0",
  "description": "Enrich any LinkedIn profile or company website into a qualified lead with AI-powered ICP scoring",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/website.js"],
      "run_at": "document_idle",
      "exclude_matches": ["https://www.linkedin.com/*"]
    }
  ],
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*", "<all_urls>"]
}
